# --- User & Auth Variables ---
@test_name = Test User
@test_email = test.admin@example.com
@test_password = supersecret123

# ====================================================================================
# S E C T I O N   1:   A U T H E N T I C A T I O N   F L O W
# ====================================================================================

### 1. Register a new user
# @name registerUser
POST {{ host }}/v1/auth/register
Content-Type: application/json

{
  "name": "{{test_name}}",
  "email": "{{test_email}}",
  "password": "{{test_password}}"
}

### 2. Attempt to register the SAME user again
# This should fail with a 409 Conflict error.
POST {{ host }}/v1/auth/register
Content-Type: application/json

{
  "name": "{{test_name}}",
  "email": "{{test_email}}",
  "password": "{{test_password}}"
}

### 3. Log in with INVALID credentials
# This should fail with a 401 Unauthorized error.
POST {{ host }}/v1/auth/login
Content-Type: application/json

{
  "email": "{{test_email}}",
  "password": "wrong-password"
}

### 4. Log in with VALID credentials
# This should succeed. The JWT token is captured into the jwt_token variable.
# @name login
POST {{ host }}/v1/auth/login
Content-Type: application/json

{
  "email": "{{test_email}}",
  "password": "{{test_password}}"
}

> {%
    client.global.set("jwt_token", response.body.token);
%}

### 5. (Example) Create a new league using the captured token
# This is an example of how you would use the token for protected routes.
# The route itself may not be protected yet.
POST {{ host }}/league
Content-Type: application/json
Authorization: Bearer {{jwt_token}}

{
  "name": "Testing authenticated leagues"
}


### ====================================================================================
# S E C T I O N   2:   E X I S T I N G   A P I   E N D P O I N T S
### ====================================================================================

@leagueId = 019c13d2-e9c4-797a-bf1d-50fcef48df4b
@gameId = 019c027a-2338-7bfe-8bac-d0d1246346ab
@memberId = 019c027a-2338-7bfe-8bac-d0d1246346ab // Replace with actual member ID
@paymentId = 019c027a-2338-7bfe-8bac-d0d1246346ab // Replace with actual payment ID


### Leagues:GetById
GET {{ host }}/league/{{leagueId}}
Authorization: Bearer {{jwt_token}}

### Leagues:Add Member
POST {{ host }}/league/{{leagueId}}/members
Content-Type: application/json
Authorization: Bearer {{jwt_token}}

{
  "userId": "{{$random.uuid}}",
  "role": "user"
}

### Leagues:List Members
GET {{ host }}/league/{{leagueId}}/members
Authorization: Bearer {{jwt_token}}

### Leagues:Update Member Role
PATCH {{ host }}/league/{{leagueId}}/members/{{memberId}}
Content-Type: application/json
Authorization: Bearer {{jwt_token}}

{
  "role": "admin"
}

### Leagues:Remove Member
DELETE {{ host }}/league/{{leagueId}}/members/{{memberId}}
Authorization: Bearer {{jwt_token}}

### Leagues:Delete
DELETE {{ host }}/league/{{leagueId}}
Authorization: Bearer {{jwt_token}}


### Games:List For League
GET {{ host }}/league/{{leagueId}}/games
Authorization: Bearer {{jwt_token}}

### Games:Create For League
POST {{ host }}/league/{{leagueId}}/games
Content-Type: application/json
Authorization: Bearer {{jwt_token}}

{
  "location": "Fairview Wellness Center",
  "costInCents": 700
}

### Games:Get By ID
GET {{ host }}/games/{{gameId}}

### Games:Update
PUT {{ host }}/games/{{gameId}}
Content-Type: application/json
Authorization: Bearer {{jwt_token}}

{
  "location": "New Community Center",
  "costInCents": 600,
  "isCanceled": false
}

### Games:Cancel
DELETE {{ host }}/games/{{gameId}}
Authorization: Bearer {{jwt_token}}


### Game Attendance:Mark User Attending
POST {{ host }}/games/{{gameId}}/attendance
Content-Type: application/json
Authorization: Bearer {{jwt_token}}

{
  "userId": "{{$random.uuid}}",
  "checkedIn": true
}

### Game Attendance:Remove User Attendance
DELETE {{ host }}/games/{{gameId}}/attendance/{{memberId}}
Authorization: Bearer {{jwt_token}}


### Payments:List For League
GET {{ host }}/league/{{leagueId}}/payments

### Payments:Record New Payment
POST {{ host }}/league/{{leagueId}}/payments
Content-Type: application/json
Authorization: Bearer {{jwt_token}}

{
  "userId": "{{$random.uuid}}",
  "amountCents": 1000,
  "method": "venmo",
  "reference": "Payment for April games"
}

### Payments:Allocate to Game Charge
POST {{ host }}/payments/{{paymentId}}/allocations
Content-Type: application/json
Authorization: Bearer {{jwt_token}}

{
  "gameChargeId": "{{$random.uuid}}",
  "amountCents": 500
}
